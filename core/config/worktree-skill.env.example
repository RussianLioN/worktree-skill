# Portable worktree-skill defaults

# Topology registry targets. Host projects may override these.
WORKTREE_SKILL_TOPOLOGY_DOC=docs/GIT-TOPOLOGY-REGISTRY.md
WORKTREE_SKILL_TOPOLOGY_INTENT=docs/GIT-TOPOLOGY-INTENT.yaml

# Optional issue-tracker integration.
WORKTREE_SKILL_ISSUE_TRACKER=auto

# Optional host default branch override.
WORKTREE_SKILL_DEFAULT_BRANCH=main

# Canonical branch used by topology and branch-status helpers.
WORKTREE_SKILL_CANONICAL_BRANCH=main
